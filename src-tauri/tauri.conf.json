{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Droidsmith",
  "version": "0.9.12",
  "identifier": "com.droidsmith.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Droidsmith",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "theme": "Dark",
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data: https://asset.localhost; script-src 'self'; style-src 'self'; connect-src 'self' ipc: http://ipc.localhost; font-src 'self' data:; object-src 'none'; base-uri 'none'; frame-ancestors 'none'",
      "pattern": {
        "use": "isolation",
        "options": {
          "dir": "../isolation"
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Droidsmith contributors",
    "copyright": "Copyright (c) Droidsmith contributors",
    "homepage": "https://github.com/SysAdminDoc/Droidsmith",
    "category": "DeveloperTool",
    "shortDescription": "Open-source ADB GUI",
    "longDescription": "Cross-platform open-source GUI for managing Android devices over ADB. A modern, MIT-licensed alternative to ADB AppControl with no paywalled features and no telemetry.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../packs/amazon-fireos.yaml": "packs/amazon-fireos.yaml",
      "../packs/motorola.yaml": "packs/motorola.yaml",
      "../packs/nothing-os.yaml": "packs/nothing-os.yaml",
      "../packs/oneplus-oxygenos.yaml": "packs/oneplus-oxygenos.yaml",
      "../packs/oppo-coloros.yaml": "packs/oppo-coloros.yaml",
      "../packs/pixel.yaml": "packs/pixel.yaml",
      "../packs/realme-ui.yaml": "packs/realme-ui.yaml",
      "../packs/samsung-oneui.yaml": "packs/samsung-oneui.yaml",
      "../packs/xiaomi-hyperos.yaml": "packs/xiaomi-hyperos.yaml",
      "../quirks/": "quirks/"
    }
  }
}
